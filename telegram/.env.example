
# Telegram Configuration
# Token for Price Tracker Bot
TELEGRAM_BOT_TOKEN=your_price_tracker_bot_token_here
# Token for Price History Bot
HISTORY_BOT_TOKEN=your_price_history_bot_token_here

# Channel Verification
# Channel that users must join (e.g. @lootsexpert or channel ID -100xxx)
AUTH_CHANNEL=@lootsexpert
TELEGRAM_CHANNEL=@lootsexpert

# Bot Usernames (for deep links interaction)
PRICE_TRACKER_BOT_USERNAME=PriceTrackerBot
PRICE_HISTORY_BOT_USERNAME=The_PriceHistory_Bot

# Admin Configuration (comma-separated Telegram user IDs)
ADMIN_IDS=your_telegram_user_id

# Database Configuration (Optional fallback exists)
DATABASE_URL=postgresql://postgres:...

# API Endpoint URL (pointing to the Express backend server)
SCRAPER_API_URL=http://localhost:3000

# Affiliate Configuration
AMAZON_AFF_TAG=wishlink_923495-21
EARNKARO_API=your_earnkaro_api_key

# Product Tracking Limit
MAX_TRACK_PRODUCTS=10
TRACKING_INTERVAL_MINUTES=30
CACHE_TIME=900
ENABLE_CACHE=True

