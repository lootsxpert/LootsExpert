# Server Configuration
PORT=3000

# Proxy & Anti-Bot Service Keys (Optional - configure one of these for reliable scraping in production)
SCRAPERAPI_KEY=
SCRAPINGBEE_KEY=
PROXY_URL=

# ScraperAPI Options (Optional - set to 'true' for JS rendering/premium rotating IPs, 'in' to target India proxies)
SCRAPERAPI_RENDER=false
SCRAPERAPI_PREMIUM=false
SCRAPERAPI_COUNTRY=in

# ScrapingBee Options (Optional)
SCRAPINGBEE_RENDER=false
SCRAPINGBEE_PREMIUM=false
SCRAPINGBEE_COUNTRY=in
