# Flask Server Configuration
PORT=5000

# Centralized Node.js API Scraping Server URL
# For local development: http://localhost:3000
# For production: https://your-node-api.up.railway.app
NODE_API_URL=http://localhost:3000

# Cloudinary Image Upload Configuration
# You can set either the full URL or configure individual keys:
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
